function scoreAuthorityFileName(baseName, p) {
const name = normalizeFileToken(baseName); if(!name) return 0;
const president = normalizeFileToken(p.presidente); const country = normalizeFileToken(p.nombre);
const nameTokens = new Set(name.split('_').filter(Boolean));
const tokenMinLength = name.length <= 6 ? 2 : 3;
const presidentTokens = getNameTokens(president, tokenMinLength);
const countryTokens = getNameTokens(country, tokenMinLength);
let score = 0;
if(president && name === president) score += 24;
if(country && name === country) score += 18;
if(president && name.includes(president)) score += 14;
if(country && name.includes(country)) score += 10;
if(president && country && name.includes(`${president}_${country}`)) score += 20;
if(president && country && name.includes(`${country}_${president}`)) score += 18;
if(presidentTokens.length && presidentTokens.every(t => nameTokens.has(t))) score += 8;
if(countryTokens.length && countryTokens.every(t => nameTokens.has(t))) score += 6;
score += presidentTokens.filter(token => nameTokens.has(token)).length * 2;
score += countryTokens.filter(token => nameTokens.has(token)).length * 1.5;
if(presidentTokens.some(token => nameTokens.has(token)) && countryTokens.some(token => nameTokens.has(token))) score += 5;
return score;
}
function readFileAsDataURL(file) {
return new Promise((resolve, reject) => {
