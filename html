<style>
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Space+Grotesk:wght@400;500;600;700&display=swap');
* { margin: 0; padding: 0; box-sizing: border-box; }
:root {
--bg-dark: #0a0a0a;
--bg-panel: #141414;
--bg-card: #1f1f1f;
--bg-input: #2a2a2a;
--gold-primary: #D4AF37;
--gold-light: #F1C40F;
--gold-dark: #AA771C;
--orange-primary: #E67E22;
--orange-light: #F39C12;
--text-main: #ffffff;
--text-muted: #aaaaaa;
--region-norte: #ef4444;
--region-occidental: #3b82f6;
--region-central: #10b981;
--region-oriental: #f59e0b;
--region-austral: #9b5cf6;
}
body { font-family: 'Inter', sans-serif; background: var(--bg-dark); color: var(--text-main); overflow-x: hidden; min-height: 100vh; }
body::before { content: ''; position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: radial-gradient(ellipse at 20% 50%, rgba(212, 175, 55, 0.05) 0%, transparent 50%), radial-gradient(ellipse at 80% 20%, rgba(230, 126, 34, 0.05) 0%, transparent 50%); z-index: -1; }
button, input, select, textarea { font: inherit; }
button { touch-action: manipulation; -webkit-tap-highlight-color: rgba(212, 175, 55, 0.15); user-select: none; }
html { color-scheme: dark; }
body { line-height: 1.6; }
button, .header-btn, .module-btn, .filter-btn, .modal-close, .popup-btn, .region-tab, .lang-btn, .admin-btn, .authority-filter-btn {
transition: transform 0.18s ease, box-shadow 0.18s ease, background-color 0.18s ease, color 0.18s ease;
}
button:focus-visible, .header-btn:focus-visible, .module-btn:focus-visible, .filter-btn:focus-visible, .modal-close:focus-visible, .popup-btn:focus-visible, .region-tab:focus-visible, .lang-btn:focus-visible, .admin-btn:focus-visible, .authority-filter-btn:focus-visible {
outline: 3px solid rgba(212, 175, 55, 0.85); outline-offset: 3px;
}
@media (max-width: 768px) {
button, .modal-close, .header-btn, .module-btn, .filter-btn, .modal-tab, .region-tab, .lang-btn, .admin-btn, .authority-filter-btn {
min-height: 44px; min-width: 44px;
}
}
/* FONDO DE INICIO DE SESIÓN */
#loginPage {
min-height: 100vh; display: flex; flex-direction: column; align-items: center; justify-content: center;
position: relative; overflow: hidden;
background: url('https://images.unsplash.com/photo-1516426122078-c23e76319801?auto=format&fit=crop&q=80&w=2044') center center / cover no-repeat;
background-attachment: scroll;
}
#loginPage::before {
content: ''; position: absolute; inset: 0;
background: rgba(10, 10, 10, 0.75); backdrop-filter: blur(4px); -webkit-backdrop-filter: blur(4px); z-index: 1;
}
#loginPage > * { position: relative; z-index: 5; }
.dev-banner { position: fixed; top: 0; left: 0; right: 0; background: linear-gradient(90deg, var(--orange-primary), var(--gold-primary), var(--orange-primary)); background-size: 200% 100%; animation: bannerShine 3s linear infinite; color: #000; text-align: center; padding: 10px; font-weight: 700; font-size: 13px; letter-spacing: 3px; text-transform: uppercase; z-index: 9999; }
@keyframes bannerShine { 0% { background-position: -200% 0; } 100% { background-position: 200% 0; } }
.login-container { background: rgba(20, 20, 20, 0.92); border: 1px solid var(--gold-primary); border-radius: 24px; padding: 50px 45px; width: 440px; max-width: 92%; text-align: center; position: relative; z-index: 5; box-shadow: 0 0 30px rgba(212, 175, 55, 0.2); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); animation: fadeInUp 0.6s ease; }
.login-logos { display: flex; justify-content: center; align-items: center; gap: 20px; margin-bottom: 25px; flex-wrap: wrap; }
.logo-img { height: clamp(55px, 14vw, 80px); width: auto; object-fit: contain; filter: drop-shadow(0 0 10px rgba(212,175,55,0.3)); }
.venezuela-flag { height: clamp(40px, 10vw, 60px); width: auto; border-radius: 4px; box-shadow: 0 0 10px rgba(255,255,255,0.1); }
.login-container h1 { font-family: 'Space Grotesk', sans-serif; font-size: clamp(26px, 7vw, 32px); font-weight: 800; color: var(--gold-primary); margin-bottom: 6px; }
.login-container h2 { font-size: clamp(11px, 2.5vw, 13px); font-weight: 400; color: var(--text-muted); margin-bottom: 35px; }
.login-field { margin-bottom: 20px; text-align: left; position: relative; }
.login-field label { display: block; color: var(--gold-primary); font-size: 12px; font-weight: 600; margin-bottom: 8px; text-transform: uppercase; }
.login-field input { width: 100%; padding: 15px 18px 15px 48px; background: var(--bg-input); border: 2px solid rgba(212, 175, 55, 0.3); border-radius: 14px; font-size: clamp(14px, 3.5vw, 15px); color: white; outline: none; }
.login-field input:focus { border-color: var(--gold-primary); box-shadow: 0 0 0 4px rgba(212, 175, 55, 0.15); }
.login-field .field-icon { position: absolute; left: 16px; bottom: 14px; color: var(--gold-primary); font-size: 16px; }
.login-btn { width: 100%; padding: 16px; background: linear-gradient(135deg, var(--gold-primary), var(--orange-primary)); color: #000; border: none; border-radius: 14px; font-size: clamp(14px, 3.5vw, 16px); font-weight: 700; cursor: pointer; margin-top: 10px; }
.login-btn:hover { transform: translateY(-3px); box-shadow: 0 12px 35px rgba(212, 175, 55, 0.3); }
.login-error { color: var(--orange-primary); font-size: 13px; margin-top: 12px; display: none; padding: 10px; background: rgba(230, 126, 34, 0.1); border-radius: 10px; }
.login-footer { margin-top: 30px; font-size: clamp(10px, 2vw, 11px); color: var(--text-muted); line-height: 1.6; }
/* Selector de idiomas profesional */
.lang-wrapper { position: absolute; top: 14px; right: 14px; z-index: 100; }
.lang-toggle-btn {
display: flex; align-items: center; gap: 8px;
padding: 10px 16px; min-height: 44px;
background: rgba(0,0,0,0.7); border: 1px solid rgba(212, 175, 55, 0.4);
border-radius: 12px; color: var(--gold-primary);
cursor: pointer; font-size: clamp(12px, 2.5vw, 13px); font-weight: 600;
backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px);
transition: all 0.2s ease;
}
.lang-toggle-btn:hover { background: var(--gold-primary); color: #000; }
.lang-toggle-btn i.fa-chevron-down { font-size: 10px; transition: transform 0.2s ease; }
.lang-toggle-btn i.fa-chevron-down.open { transform: rotate(180deg); }
.lang-dropdown {
position: absolute; top: 100%; right: 0; margin-top: 8px;
background: rgba(18, 18, 18, 0.95); border: 1px solid var(--gold-primary);
border-radius: 14px; padding: 6px; min-width: 180px;
box-shadow: 0 8px 24px rgba(0,0,0,0.4);
opacity: 0; visibility: hidden; transform: translateY(-8px);
transition: all 0.2s ease;
backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
}
.lang-dropdown.show { opacity: 1; visibility: visible; transform: translateY(0); }
.lang-option {
display: flex; align-items: center; gap: 10px;
padding: 10px 14px; min-height: 44px;
border: none; background: none; width: 100%;
color: var(--text-muted); cursor: pointer;
border-radius: 10px; font-size: clamp(12px, 2.5vw, 13px); font-weight: 500;
transition: all 0.15s ease; text-align: left;
}
.lang-option:hover { background: rgba(212, 175, 55, 0.12); color: var(--gold-primary); }
.lang-option.active { background: linear-gradient(135deg, var(--gold-primary), var(--orange-primary)); color: #000; }
.lang-option .lang-flag { font-size: 18px; flex-shrink: 0; }
#appPage { display: none; min-height: 100vh; }
.app-header { background: var(--bg-panel); border-bottom: 1px solid var(--gold-primary); color: white; padding: 0 25px; height: 65px; display: flex; align-items: center; justify-content: space-between; position: sticky; top: 0; z-index: 1000; }
.app-header h1 { font-family: 'Space Grotesk', sans-serif; font-size: clamp(16px, 4vw, 22px); font-weight: 700; display: flex; align-items: center; gap: 12px; color: var(--gold-primary); white-space: nowrap; }
.app-header h1 .logo-icon { width: clamp(28px, 7vw, 40px); height: clamp(28px, 7vw, 40px); background: linear-gradient(135deg, var(--gold-primary), var(--orange-primary)); border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: clamp(14px, 3.5vw, 20px); color: #000; flex-shrink: 0; }
.header-right { display: flex; align-items: center; gap: 12px; flex-wrap: wrap; }
.header-btn { background: rgba(255,255,255,0.05); border: 1px solid var(--gold-dark); color: var(--gold-primary); padding: 8px 14px; border-radius: 12px; cursor: pointer; font-size: clamp(11px, 2vw, 13px); display: flex; align-items: center; gap: 8px; transition: background 0.15s; min-height: 40px; }
.header-btn:hover { background: var(--gold-primary); color: #000; }
.header-user { display: flex; align-items: center; gap: 10px; background: rgba(255,255,255,0.05); border: 1px solid var(--gold-dark); padding: 6px 12px; border-radius: 14px; font-size: clamp(11px, 2vw, 13px); color: var(--gold-primary); min-height: 40px; }
.header-user .avatar { width: clamp(24px, 5vw, 32px); height: clamp(24px, 5vw, 32px); background: linear-gradient(135deg, var(--gold-primary), var(--orange-primary)); border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: clamp(11px, 2.5vw, 14px); color: #000; }
.role-badge { font-size: 10px; padding: 2px 8px; border-radius: 6px; font-weight: 600; }
.role-admin { background: rgba(212, 175, 55, 0.2); color: var(--gold-primary); }
.role-viewer { background: rgba(230, 126, 34, 0.2); color: var(--orange-primary); }
.module-nav { display: flex; gap: 6px; padding: 12px 25px; background: var(--bg-panel); border-bottom: 1px solid rgba(212, 175, 55, 0.3); overflow-x: auto; -webkit-overflow-scrolling: touch; scrollbar-width: thin; scrollbar-color: var(--gold-dark) var(--bg-panel); }
.module-nav::-webkit-scrollbar { height: 3px; }
.module-nav::-webkit-scrollbar-track { background: var(--bg-panel); }
.module-nav::-webkit-scrollbar-thumb { background: var(--gold-dark); border-radius: 3px; }
.module-btn { padding: 8px 16px; border: 1px solid rgba(212, 175, 55, 0.3); border-radius: 12px; background: var(--bg-card); cursor: pointer; font-size: clamp(11px, 2.5vw, 13px); color: var(--text-muted); white-space: nowrap; display: flex; align-items: center; gap: 8px; min-height: 40px; }
.module-btn:hover { border-color: var(--gold-primary); color: var(--gold-primary); }
.module-btn.active { background: linear-gradient(135deg, var(--gold-primary), var(--orange-primary)); color: #000; border-color: transparent; }
.app-layout { display: flex; height: calc(100vh - 65px - 55px); height: calc(100dvh - 65px - 55px); }
.sidebar { width: 290px; min-width: 0; flex-shrink: 0; background: var(--bg-panel); border-right: 1px solid var(--gold-dark); overflow-y: auto; padding: 20px; }
.sidebar::-webkit-scrollbar { width: 4px; }
.sidebar::-webkit-scrollbar-thumb { background: var(--gold-dark); border-radius: 4px; }
.sidebar h3 { font-family: 'Space Grotesk', sans-serif; font-size: clamp(13px, 3vw, 15px); font-weight: 700; color: var(--gold-primary); margin-bottom: 15px; padding-bottom: 10px; border-bottom: 2px solid var(--orange-primary); display: flex; align-items: center; gap: 8px; }
.search-wrapper { position: relative; margin-bottom: 18px; }
.search-wrapper .search-icon { position: absolute; left: 14px; top: 50%; transform: translateY(-50%); color: var(--gold-primary); font-size: 14px; pointer-events: none; }
.search-box { width: 100%; padding: 12px 14px 12px 42px; background: var(--bg-input); border: 2px solid rgba(212, 175, 55, 0.3); border-radius: 12px; font-size: clamp(12px, 2.5vw, 13px); color: white; outline: none; }
.search-box:focus { border-color: var(--gold-primary); box-shadow: 0 0 0 3px rgba(212, 175, 55, 0.15); }
.filter-group { margin-bottom: 22px; }
.filter-group h4 { color: var(--text-muted); font-size: 11px; margin-bottom: 10px; text-transform: uppercase; letter-spacing: 1.5px; font-weight: 600; }
.filter-btn { display: flex; align-items: center; gap: 10px; width: 100%; padding: 11px 14px; border: 1px solid rgba(212, 175, 55, 0.3); border-radius: 10px; background: var(--bg-card); cursor: pointer; margin-bottom: 6px; font-size: clamp(11px, 2.5vw, 13px); color: var(--text-muted); }
.filter-btn:hover { border-color: var(--gold-primary); background: rgba(212, 175, 55, 0.1); color: var(--gold-primary); }
.filter-btn.active { border-color: var(--gold-primary); background: rgba(212, 175, 55, 0.15); color: var(--gold-primary); }
.filter-dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }
.filter-count { margin-left: auto; background: rgba(255,255,255,0.1); color: var(--text-muted); font-size: 10px; padding: 2px 8px; border-radius: 8px; font-weight: 600; }
.filter-btn.active .filter-count { background: var(--gold-primary); color: #000; }
.stat-card { background: var(--bg-card); border: 1px solid rgba(212, 175, 55, 0.3); border-radius: 12px; padding: 14px; margin-bottom: 8px; display: flex; align-items: center; gap: 12px; }
.stat-icon { width: 42px; height: 42px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 18px; flex-shrink: 0; }
.stat-icon.blue { background: rgba(52, 152, 219, 0.2); color: #3498DB; }
.stat-icon.green { background: rgba(46, 204, 113, 0.2); color: #2ECC71; }
.stat-icon.purple { background: rgba(139, 92, 246, 0.2); color: #9B59B6; }
.stat-info { flex: 1; }
.stat-info .stat-num { font-family: 'Space Grotesk', sans-serif; font-size: 22px; font-weight: 700; color: var(--gold-primary); line-height: 1; }
.stat-info .stat-label { font-size: 11px; color: var(--text-muted); margin-top: 3px; }
/* FONDO DEL MAPA INTERACTIVO */
.map-area {
flex: 1; position: relative; overflow: hidden; min-height: 300px;
background: url('https://imgur.com/shgm9Wm.png') center center / cover no-repeat;
}
.map-area::before {
content: ''; position: absolute; inset: 0;
background: rgba(10, 10, 10, 0.60); z-index: 1; pointer-events: none;
}
#map { width: 100%; height: 100%; position: relative; z-index: 2; min-height: 300px; }
.leaflet-container { background: transparent !important; }
.leaflet-tile-pane { opacity: 0.85; }
.leaflet-control-zoom a {
width: 40px !important; height: 40px !important;
line-height: 40px !important; font-size: 18px !important;
}
.leaflet-popup-content-wrapper { background: var(--bg-panel) !important; border: 1px solid var(--gold-primary) !important; border-radius: 16px !important; color: white !important; max-width: 90vw; }
.leaflet-popup-tip { background: var(--bg-panel) !important; border: 1px solid var(--gold-primary) !important; }
.leaflet-popup-content { margin: 15px !important; font-family: 'Inter', sans-serif !important; }
.popup-content { text-align: center; min-width: 200px; }
.popup-flag-img { width: 64px; height: 43px; border-radius: 6px; object-fit: cover; margin: 0 auto 8px; display: block; border: 2px solid var(--gold-primary); }
.popup-name { font-family: 'Space Grotesk', sans-serif; font-weight: 700; font-size: 16px; color: var(--gold-primary); margin-bottom: 4px; }
.popup-capital { font-size: 12px; color: var(--text-muted); margin-bottom: 2px; }
.popup-president { font-size: 12px; color: var(--orange-primary); font-weight: 500; margin-bottom: 8px; }
.popup-btn { display: inline-flex; align-items: center; gap: 6px; margin-top: 8px; padding: 8px 18px; background: linear-gradient(135deg, var(--gold-primary), var(--orange-primary)); color: #000; border-radius: 10px; font-size: 12px; font-weight: 600; cursor: pointer; border: none; min-height: 40px; }
.country-modal { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.8); z-index: 2000; align-items: center; justify-content: center; padding: 20px; }
.country-modal.show { display: flex; }
.modal-content { background: var(--bg-panel); border: 1px solid var(--gold-primary); border-radius: 20px; width: min(950px, 100%); max-width: 96%; max-height: 92vh; max-height: 92dvh; overflow-y: auto; animation: modalIn 0.3s ease; }
@keyframes modalIn { from { opacity: 0; transform: scale(0.9) translateY(20px); } to { opacity: 1; transform: scale(1) translateY(0); } }
.modal-header { padding: clamp(16px, 3vw, 30px) clamp(16px, 3vw, 35px) 20px; display: flex; align-items: center; gap: 20px; border-bottom: 1px solid var(--gold-dark); flex-wrap: wrap; }
.modal-flag-big { width: clamp(60px, 12vw, 80px); height: clamp(40px, 8vw, 53px); border-radius: 10px; object-fit: cover; border: 2px solid var(--gold-primary); flex-shrink: 0; }
.modal-title { flex: 1; min-width: 140px; }
.modal-title h2 { font-family: 'Space Grotesk', sans-serif; font-size: clamp(20px, 4.5vw, 28px); font-weight: 800; color: var(--gold-primary); }
.modal-title p { font-size: clamp(12px, 2.5vw, 14px); color: var(--text-muted); }
.modal-close { width: 40px; height: 40px; background: rgba(255,255,255,0.05); border: 1px solid rgba(212, 175, 55, 0.3); color: white; border-radius: 12px; font-size: 18px; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: background 0.15s; }
.modal-close:hover { background: var(--orange-primary); }
.modal-body { padding: clamp(16px, 3vw, 25px) clamp(16px, 3vw, 35px) clamp(20px, 4vw, 30px); }
.modal-tabs { display: flex; gap: 4px; margin-bottom: 22px; border-bottom: 1px solid rgba(212, 175, 55, 0.3); overflow-x: auto; -webkit-overflow-scrolling: touch; scrollbar-width: none; }
.modal-tabs::-webkit-scrollbar { display: none; }
.modal-tab { padding: 12px clamp(12px, 3vw, 20px); border: none; background: none; cursor: pointer; font-size: clamp(11px, 2.5vw, 13px); color: var(--text-muted); border-bottom: 3px solid transparent; transition: color 0.15s, border-color 0.15s; min-height: 44px; }
.modal-tab:hover { color: var(--gold-primary); }
.modal-tab.active { color: var(--gold-primary); border-bottom-color: var(--gold-primary); font-weight: 600; }
.tab-content { display: none; }
.tab-content.active { display: block; animation: fadeIn 0.3s ease; }
@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
.info-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(min(100%, 280px), 1fr)); gap: 14px; }
.info-item { background: var(--bg-card); border: 1px solid rgba(212, 175, 55, 0.3); border-radius: 14px; padding: 16px; border-left: 4px solid var(--gold-primary); }
.info-item .label { font-size: 10px; color: var(--text-muted); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 6px; font-weight: 600; }
.info-item .value { font-size: clamp(13px, 2.5vw, 14px); color: white; line-height: 1.5; word-break: break-word; }
.info-item.full { grid-column: 1 / -1; }
.badge { display: inline-block; padding: 4px 12px; border-radius: 8px; font-size: 11px; font-weight: 600; }
.badge-green { background: rgba(46, 204, 113, 0.15); color: #2ECC71; }
.badge-blue { background: rgba(52, 152, 219, 0.15); color: #3498DB; }
.badge-orange { background: rgba(245, 158, 11, 0.15); color: #F39C12; }
.badge-red { background: rgba(231, 76, 60, 0.15); color: #E74C3C; }
.badge-purple { background: rgba(139, 92, 246, 0.15); color: #9B59B6; }
.module-content { padding: clamp(16px, 3vw, 25px); display: none; max-height: calc(100vh - 120px - 55px); overflow-y: auto; }
.module-panel { display: none; }
.module-panel.active { display: block; animation: fadeIn 0.3s ease; }
.table-wrapper { overflow-x: auto; -webkit-overflow-scrolling: touch; border-radius: 16px; border: 1px solid rgba(212, 175, 55, 0.3); margin-bottom: 16px; }
.data-table { width: 100%; border-collapse: separate; border-spacing: 0; background: var(--bg-card); border-radius: 16px; overflow: hidden; }
.data-table th { background: linear-gradient(135deg, var(--gold-dark), var(--gold-primary)); color: #000; padding: clamp(10px, 2vw, 14px) clamp(12px, 2.5vw, 18px); text-align: left; font-size: clamp(10px, 2vw, 12px); font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; white-space: nowrap; position: sticky; top: 0; z-index: 10; }
.data-table td { padding: clamp(8px, 2vw, 12px) clamp(12px, 2.5vw, 18px); border-bottom: 1px solid rgba(255,255,255,0.05); font-size: clamp(11px, 2.5vw, 13px); color: var(--text-main); word-break: break-word; }
.data-table tbody tr:hover { background: rgba(212, 175, 55, 0.05); }
.flag-cell { display: flex; align-items: center; gap: 10px; }
.flag-cell img { width: 28px; height: 19px; border-radius: 3px; object-fit: cover; }
.card-row { display: grid; grid-template-columns: repeat(auto-fill, minmax(min(100%, 280px), 1fr)); gap: 16px; margin-top: 15px; }
.info-card { background: var(--bg-card); border: 1px solid rgba(212, 175, 55, 0.3); border-radius: 16px; padding: 22px; cursor: pointer; position: relative; overflow: hidden; transition: all 0.3s; }
.info-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px; background: linear-gradient(90deg, var(--gold-primary), var(--orange-primary)); }
.info-card:hover { transform: translateY(-4px); box-shadow: 0 12px 35px rgba(0,0,0,0.5); border-color: var(--gold-primary); }
.info-card .card-header { display: flex; align-items: center; gap: 12px; margin-bottom: 12px; }
