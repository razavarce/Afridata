async function fetchWikiPortraitByTitle(title) {
if(!title) return '';
try {
const url = `https://es.wikipedia.org/api/rest_v1/page/summary/${encodeURIComponent(title)}`;
const res = await fetch(url);
if(res.ok) {
const data = await res.json();
const src = data?.originalimage?.source || data?.thumbnail?.source || '';
if(src && !src.includes('/static/images/icons/')) return src;
}
} catch (e) {}
try {
const url = `https://en.wikipedia.org/api/rest_v1/page/summary/${encodeURIComponent(title)}`;
const res = await fetch(url);
if(!res.ok) return '';
const data = await res.json();
const src = data?.originalimage?.source || data?.thumbnail?.source || '';
if(src && !src.includes('/static/images/icons/')) return src;
} catch (e) {}
return '';
}
async function findAuthorityPhotoOnline(p) {
