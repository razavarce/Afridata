{
	"version": "2.0.0",
	"tasks": [
		{
			"type": "npm",
			"script": "dev",
			"path": "app",
			"isBackground": true,
			"problemMatcher": [
				{
					"pattern": [
						{
							"regexp": "."
						}
					],
					"background": {
						"activeOnStart": true,
						"beginsPattern": ".*",
						"endsPattern": "ready in"
					}
				}
			],
			"label": "npm: dev - app",
			"detail": "run Vite development server"
		},
		{
			"type": "npm",
			"script": "install",
			"path": "app",
			"group": "clean",
			"problemMatcher": [],
			"label": "npm: install - app",
			"detail": "install dependencies from package"
		}
	]
}